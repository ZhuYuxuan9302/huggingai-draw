# =============================================================
# 应用基础
# =============================================================
NODE_ENV=development
# 0=禁用，1=启用详细日志
DEBUG=0

# 应用外部访问地址（用于 OIDC 回调拼接 redirect_uri）
# 例：http://localhost:3000  或  https://draw.example.com
APP_BASE_URL=http://localhost:3000

# 会话加密密钥，至少 32 字符（生产环境务必更换）
SESSION_SECRET=please-change-me-to-a-very-long-random-string-32+

# 管理员邮箱白名单（逗号分隔，大小写不敏感）
ADMIN_EMAILS=admin@example.com

# =============================================================
# 本系统数据库（Prisma，运行迁移用）
# =============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/lottery?schema=public"

# =============================================================
# newapi 数据库（只读写 users 表的 quota / used_quota / oidc_id）
# 不运行迁移，仅用于 ORM 查询/更新
# =============================================================
NEWAPI_DATABASE_URL="postgresql://user:password@localhost:5432/newapi?schema=public"

# =============================================================
# OIDC 配置（Authentik / 通用 OIDC，通过 .well-known 自动发现）
# =============================================================
OIDC_ISSUER=https://auth.example.com/application/o/lottery/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# 可选：覆盖 discovery URL（当 issuer 不直接提供 .well-known 时）
# OIDC_METADATA_URL=
# 可选：额外 scopes，默认 openid profile email
OIDC_SCOPES="openid email profile"
